# ================================================================
# .env.example — 환경변수 템플릿
#
# 사용법:
# 1. 이 파일을 .env 로 복사: cp .env.example .env
# 2. .env 파일 내 각 값 채우기
# 3. .env 는 .gitignore 에 포함되어 있어 Git에 커밋되지 않음
# 4. SUPABASE_SERVICE_ROLE_KEY 는 절대 공개 금지
# ================================================================

# Supabase 연결
SUPABASE_URL=https://vogyfomyhrvqswivqhdv.supabase.co

# Supabase 공개 키 (RLS 적용됨, 노출돼도 안전)
SUPABASE_ANON_KEY=

# Supabase 서비스 롤 키 (RLS 우회, 절대 공개 금지)
# Supabase 대시보드 → Settings → API → service_role 에서 복사
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 URL (canonical, sitemap 생성에 사용)
SITE_URL=https://undercov.kr
